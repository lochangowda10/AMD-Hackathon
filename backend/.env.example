from pydantic_settings import BaseSettings


class Settings(BaseSettings):
    APP_NAME: str = "AI Swing Trading Copilot"
    APP_VERSION: str = "1.0.0"

    FIREWORKS_API_KEY: str = ""
    DATABASE_URL: str = ""
    REDIS_URL: str = ""
    VECTOR_DB_PATH: str = "./vector_db"

    MODEL_NAME: str = "accounts/fireworks/models/llama4-maverick-instruct-basic"

    SECRET_KEY: str = ""

    class Config:
        env_file = ".env"


settings = Settings()