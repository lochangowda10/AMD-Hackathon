# ── Database (Postgres, e.g. Neon / Supabase / Railway) ──────────────────────
DATABASE_URL="postgresql://user:password@host:5432/navia?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Your deployed URL (Vercel sets this automatically in most cases)
NEXTAUTH_URL="https://navia-ai.vercel.app"

# ── AI Provider (set exactly ONE of these) ───────────────────────────────────
# Powers: multi-agent analysis, chat copilot, Vision AI, psychology coach,
# weekly reports, market memory, portfolio health, and (optionally) server-side
# speech-to-text. Voice input/output also works with ZERO keys via the
# browser's built-in Web Speech API on Chrome / Edge / Safari.

# Option A - Fireworks AI (same key as the FastAPI backend; Llama 4 Maverick
# is multimodal, so it powers chat AND chart vision)
FIREWORKS_API_KEY=""

# Option B - Groq (free tier; Llama 3.3 chat + Llama 4 Scout vision + Whisper ASR + TTS)
# GROQ_API_KEY=""

# Option C - OpenAI (gpt-4o-mini chat/vision + Whisper + TTS)
# OPENAI_API_KEY=""

# Optional fine-grained overrides
# AI_BASE_URL=""        # any OpenAI-compatible endpoint
# AI_API_KEY=""
# AI_MODEL=""           # chat model id
# AI_VISION_MODEL=""    # vision-capable model id

# ── Optional: mirror signups to the FastAPI backend ──────────────────────────
# NEXT_PUBLIC_BACKEND_URL="https://your-fastapi-backend.example.com"
